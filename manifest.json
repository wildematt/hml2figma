{
  "manifest_version": 3,
  "name": "Html2Figma",
  "description": "一键把网页转换为Figma设计稿",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_title": "Html2Figma",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}